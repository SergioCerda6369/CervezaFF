CREATE TABLE material (
    id_material INT AUTO_INCREMENT PRIMARY KEY,
    nombre_material VARCHAR(255) NOT NULL,
    cantidad_stock INT NOT NULL,
    nombre_proveedor VARCHAR(255) NOT NULL
);

